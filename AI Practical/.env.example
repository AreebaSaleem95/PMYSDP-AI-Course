# Azure Content Safety - Environment Variables Template
# =====================================================
#
# INSTRUCTIONS:
# 1. Rename this file to ".env" (remove the .example extension)
# 2. Replace the values with your actual Azure credentials
# 3. Update config.py to read from this file using python-dotenv
#
# SECURITY: This file should NEVER be committed to version control
# Add ".env" to your .gitignore file
#

# Azure Subscription Key
# Get from: Azure Portal -> Your Resource -> Keys and Endpoint -> Key1 or Key2
AZURE_API_KEY=your_api_key_here

# Azure API Endpoint
# Get from: Azure Portal -> Your Resource -> Keys and Endpoint -> Endpoint
# Format: https://resource-name.cognitiveservices.azure.com
AZURE_ENDPOINT=https://your_resource_name.cognitiveservices.azure.com

# Severity Threshold (0-6)
# 0 = Safe, 6 = Highly unsafe
# Content with severity >= threshold will be blocked
SEVERITY_THRESHOLD=2

# Debug Mode (true/false)
DEBUG_MODE=false

# Flask Settings (for web API)
FLASK_HOST=localhost
FLASK_PORT=5000
FLASK_DEBUG=true
